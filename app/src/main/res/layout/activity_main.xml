<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="28dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/text_primary_dark"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/app_description"
            android:textColor="@color/text_secondary_dark"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/setup_panel_background"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/permissionStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/permission_needed_status"
                android:textColor="@color/text_primary_dark"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/timeoutValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/current_timeout_unknown"
                android:textColor="@color/text_secondary_dark"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/nextAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/next_action_grant_permission"
                android:textColor="@color/text_primary_dark"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/permissionButton"
                style="@style/Widget.ScreenTimeoutTile.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/permission_button_label"
                android:textSize="15sp"
                app:icon="@drawable/ic_permission_settings"
                app:iconGravity="textStart"
                app:iconPadding="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tileButton"
                style="@style/Widget.ScreenTimeoutTile.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/tile_button_label"
                android:textSize="15sp"
                app:icon="@drawable/ic_qs_timeout_long"
                app:iconGravity="textStart"
                app:iconPadding="8dp" />

            <TextView
                android:id="@+id/tileRequestStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/tile_request_status_idle"
                android:textColor="@color/text_secondary_dark"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/instructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/instructions_text"
            android:textColor="@color/text_secondary_dark"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
